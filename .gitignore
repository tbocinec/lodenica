# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.output/
*.tsbuildinfo

# Env
.env
.env.local
.env.*.local
!.env.example

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Coverage / test artifacts
coverage/
.nyc_output/

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Prisma
backend-js/prisma/migrations/dev.db*

# Docker
*.pid

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log

# Local prod env files (only the .example variant is committed)
.env.prod
infra/.env.prod

# Deploy secrets (SSH + DB credentials for Websupport).
# Local-only helper for re-running deploys; never committed.
.deploy-secrets
.deploy-secrets.*
!.deploy-secrets.example

# Stray composer installs at the repo root. The PHP backend lives in
# backend-php/ — `composer install` should NEVER run from the repo root
# (that's a misfire, e.g. running it before `cd backend-php`). The
# leading slash anchors these patterns to the repo root only; the real
# backend-php/vendor/ is still tracked by its own .gitignore rules.
/composer.json
/composer.lock
/vendor/

# Empty bind-mount target dirs Docker creates on the host when restarting
# a stale container that referenced the pre-rename `./backend/` paths.
# The real source lives in backend-js/.
/backend/

