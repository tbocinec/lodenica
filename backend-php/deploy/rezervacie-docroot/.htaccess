# Lodenica docroot — Apache routing for SPA + Laravel API
# (all-in-docroot variant where the Laravel app lives under ./laravel/).
#
# /api/v1/*, /health*, /up → Laravel (index.php)
# Existing files (SPA assets, favicon, robots) → served directly
# Anything else (Vue Router deep-links on refresh) → SPA shell (index.html)

<IfModule mod_rewrite.c>
    Options -MultiViews -Indexes

    RewriteEngine On

    # Pass Authorization header through to PHP.
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # HARD DENY — no client may reach the Laravel application directory.
    # vendor/, app/, .env etc. live there and must NEVER be served. The
    # nested laravel/.htaccess deny-all is the second line of defence;
    # this rewrite catches the most common attempt vectors first.
    RewriteRule ^laravel(/|$) - [F,L]

    # Redirect trailing slashes on non-directory URLs.
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # API + health always hit Laravel.
    RewriteRule ^api(/.*|$) index.php [L]
    RewriteRule ^health(/.*|$) index.php [L]
    RewriteRule ^up$ index.php [L]

    # Existing file or directory → let Apache serve it.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Fallback: SPA shell so Vue Router can take over on page refresh.
    RewriteRule ^ index.html [L]
</IfModule>

# Private club tool — keep search engines out of every response,
# including API JSON and SPA assets (robots.txt + meta tag cover only HTML).
<IfModule mod_headers.c>
    Header set X-Robots-Tag "noindex, nofollow"
</IfModule>

# Block any dot-files (.env, .git, .htpasswd, etc.) just in case the
# rewrite engine is ever disabled.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

DirectoryIndex index.html index.php
