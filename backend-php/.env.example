APP_NAME=Lodenica
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=sk
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=sk_SK

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=lodenica
DB_USERNAME=lodenica
DB_PASSWORD=lodenica

# Comma-separated list of origins allowed to call /api/v1/*. For same-origin
# (frontend + backend on the same host) this is irrelevant but harmless.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

SESSION_DRIVER=array
QUEUE_CONNECTION=sync
CACHE_STORE=array
