# Production .env template for Websupport PHP hosting.
# Copy to `.env` on the server and fill in REAL credentials — DO NOT commit.

APP_NAME=Lodenica
APP_ENV=production
APP_KEY=                          # `php artisan key:generate` on the server
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://tomas.gart.sk

APP_LOCALE=sk
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=sk_SK

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Websupport managed Postgres. Access restricted to hosting servers
# (cannot connect from a local laptop).
DB_CONNECTION=pgsql
DB_HOST=db.r2.websupport.sk
DB_PORT=5432
DB_DATABASE=                      # from Websupport admin (e.g. tomas-test)
DB_USERNAME=                      # from Websupport admin
DB_PASSWORD=                      # from Websupport admin
DB_SSLMODE=prefer

# Same-origin in production: frontend and API both live on tomas.gart.sk,
# so CORS isn't strictly needed by browsers. Listed anyway for clarity /
# in case a future preview deployment lives on a separate host.
CORS_ALLOWED_ORIGINS=https://tomas.gart.sk

# Stateless API; no sessions, no queues. `file` cache uses
# storage/framework/cache and is enough for Laravel's internal cache.
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
CACHE_STORE=file
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
