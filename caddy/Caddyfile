# Caddy reverse proxy with automatic Let's Encrypt TLS.
# The DOMAIN and ACME_EMAIL placeholders are templated from env vars at
# container start (see entrypoint in docker-compose.prod.yml).

{
    email {$ACME_EMAIL}
}

{$DOMAIN} {
    encode gzip
    reverse_proxy 127.0.0.1:8080

    # Sensible browser security headers.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    log {
        output stdout
        format console
    }
}

# Bare-IP / non-domain HTTP — redirect to the canonical domain.
:80 {
    redir https://{$DOMAIN}{uri} permanent
}
