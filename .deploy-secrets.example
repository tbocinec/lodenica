# Lodenica — Websupport deploy secrets (template).
# Copy to `.deploy-secrets` (gitignored) and fill in the real values.
#
# Source it before running deploys/SSH/psql against production:
#   set -a; source .deploy-secrets; set +a

# --- SSH to the Websupport shell host ---
DEPLOY_SSH_HOST='shell.r2.websupport.sk'
DEPLOY_SSH_PORT='<port>'
DEPLOY_SSH_USER='<uid…>'
DEPLOY_SSH_PASSWORD='<password>'

# --- Paths on the server ---
DEPLOY_LARAVEL_APP='<$HOME>/lodenica-app'
DEPLOY_WEB_DOCROOT='<$HOME>/gart.sk/sub/<subdomain>'

# --- Managed Postgres (only reachable from Websupport hosting) ---
PROD_DB_HOST='db.<region>.websupport.sk'
PROD_DB_PORT='5432'
PROD_DB_NAME='<dbname>'
PROD_DB_USER='<dbuser>'
PROD_DB_PASSWORD='<dbpassword>'

# --- Public site ---
PROD_DOMAIN='<your.domain>'
PROD_BASE_URL='https://<your.domain>'
