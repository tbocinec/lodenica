# Lodenica — Websupport deploy secrets (template).
# Copy to `.deploy-secrets` (gitignored) and fill in the real values.
#
# Source it before running deploys/SSH/psql against production:
#   set -a; source .deploy-secrets; set +a
#
# Two hosting profiles supported:
#   1. SSH-enabled Websupport — see DEPLOY_SSH_* + first DB block
#   2. SFTP-only Websupport   — see DEPLOY_SFTP_* + second DB block
# scripts/deploy-rezervacie.sh consumes profile #2.

#────────────────────────────────────────────────────────────────────────────
# Profile 1: SSH-enabled Websupport (e.g. tomas.gart.sk)
#────────────────────────────────────────────────────────────────────────────
DEPLOY_SSH_HOST='shell.r2.websupport.sk'
DEPLOY_SSH_PORT='<port>'
DEPLOY_SSH_USER='<uid…>'
DEPLOY_SSH_PASSWORD='<password>'

DEPLOY_LARAVEL_APP='<$HOME>/lodenica-app'
DEPLOY_WEB_DOCROOT='<$HOME>/<domain>/sub/<subdomain>'

#────────────────────────────────────────────────────────────────────────────
# Profile 2: SFTP-only Websupport (e.g. rezervacie.lodenicakvs.sk)
#
# Used by scripts/deploy-rezervacie.sh. Run with VPN OFF — port 22
# outbound through corporate VPNs is usually blocked.
#────────────────────────────────────────────────────────────────────────────
DEPLOY_SFTP_HOST='<sftp-host>'
DEPLOY_SFTP_PORT='22'
DEPLOY_SFTP_USER='<sftp-user>'
DEPLOY_SFTP_PASSWORD='<sftp-password>'

# Discover with:  scripts/deploy-rezervacie.sh --explore
DEPLOY_LARAVEL_APP_REMOTE='<remote-path>/lodenica-app'
DEPLOY_DOCROOT_REMOTE='<remote-path>/sub/<subdomain>'

# Persist this after the first deploy so re-deploys keep the same key.
# DEPLOY_APP_KEY='base64:...'

#────────────────────────────────────────────────────────────────────────────
# Managed Postgres (shared between profiles — pick whichever DB applies)
#────────────────────────────────────────────────────────────────────────────
PROD_DB_HOST='<db-host>'
PROD_DB_PORT='5432'
PROD_DB_NAME='<dbname>'
PROD_DB_USER='<dbuser>'
PROD_DB_PASSWORD='<dbpassword>'

# Public site
PROD_DOMAIN='<your.domain>'
PROD_BASE_URL='https://<your.domain>'
