# Root-level Docker Compose environment variables.
# Copy to `.env` for local development: cp .env.example .env

# PostgreSQL
POSTGRES_USER=lodenica
POSTGRES_PASSWORD=lodenica
POSTGRES_DB=lodenica
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=3000
BACKEND_NODE_ENV=development
BACKEND_LOG_LEVEL=debug
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Frontend
FRONTEND_PORT=5173
FRONTEND_API_BASE_URL=http://localhost:3000/api/v1
