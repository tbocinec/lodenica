# Production env file — SCP to /opt/lodenica/.env on the EC2 instance.
# Set a strong POSTGRES_PASSWORD before deploying.

GHCR_OWNER=tbocinec
IMAGE_TAG=latest

POSTGRES_USER=lodenica
POSTGRES_PASSWORD=CHANGE_ME_TO_SOMETHING_LONG_AND_RANDOM
POSTGRES_DB=lodenica

BACKEND_LOG_LEVEL=info

# TLS / domain — Caddy issues a Let's Encrypt cert for $DOMAIN on first run.
DOMAIN=lodenica.example.com
ACME_EMAIL=ops@example.com
BACKEND_CORS_ORIGINS=https://lodenica.example.com
