## Copy to terraform.tfvars and edit.

region        = "eu-central-1"
environment   = "production"

# t3.micro → free tier (12 months) · t4g.small → comfortable, ~$12/mo
instance_type = "t3.micro"

# Point at the repository owner of GHCR images.
github_owner  = "tbocinec"
github_repo   = "lodenica"

# Lock SSH down to your IP/32 once you have one (e.g. "203.0.113.4/32").
allowed_ssh_cidrs = ["0.0.0.0/0"]

# ssh_public_key_path = "~/.ssh/id_ed25519.pub"
